# ─── Mwanga Wallet — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=mwanga_wallet
DB_USERNAME=postgres
DB_PASSWORD=change_me_in_production

# ── Spring Boot ───────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 64
# Must decode to at least 32 bytes (256 bits) for HS256.
JWT_SECRET=REPLACE_WITH_BASE64_ENCODED_SECRET_AT_LEAST_32_BYTES

# Token lifetimes in milliseconds
JWT_EXPIRATION=86400000           # 24 hours
JWT_REFRESH_EXPIRATION=604800000  # 7 days

# ── Transfer limits (TZS) ─────────────────────────────────────────────────────
TRANSFER_MIN_AMOUNT=100
TRANSFER_MAX_AMOUNT=5000000

# ── Top-up limits (TZS) ──────────────────────────────────────────────────────
TOPUP_MIN_AMOUNT=100
TOPUP_MAX_AMOUNT=10000000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the backend (used by browser-side Next.js fetch calls)
NEXT_PUBLIC_API_URL=http://localhost:8080
